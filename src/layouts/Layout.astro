---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/utils';

export interface Props {
  title?: string;
  locale: Locale;
  currentPath?: string;
}

const { title = 'Lyra賞樂誌', locale } = Astro.props;
const path = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Sans+TC:wght@400;500;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header locale={locale} currentPath={path} />
    <main class="main-content"><slot /></main>
    <Footer locale={locale} />
    <script>
      const key = 'lyra-bookmarks';
      function getBookmarks() { return JSON.parse(localStorage.getItem(key) || '[]'); }
      function saveBookmarks(list) { localStorage.setItem(key, JSON.stringify(list)); }

      document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-bookmark]');
        if (!btn) return;
        const raw = btn.getAttribute('data-bookmark');
        if (!raw) return;
        const data = JSON.parse(raw);
        let bookmarks = getBookmarks();
        const idx = bookmarks.findIndex((b) => b.url === data.url);
        if (idx > -1) {
          bookmarks.splice(idx, 1);
          btn.classList.remove('saved');
          btn.querySelector('.bookmark-label').textContent = btn.getAttribute('data-save-label');
        } else {
          bookmarks.push(data);
          saveBookmarks(bookmarks);
          btn.classList.add('saved');
          btn.querySelector('.bookmark-label').textContent = btn.getAttribute('data-saved-label');
        }
      });

      document.querySelectorAll('[data-bookmark]').forEach((btn) => {
        const raw = btn.getAttribute('data-bookmark');
        if (!raw) return;
        const data = JSON.parse(raw);
        const bookmarks = getBookmarks();
        if (bookmarks.some((b) => b.url === data.url)) {
          btn.classList.add('saved');
          btn.querySelector('.bookmark-label').textContent = btn.getAttribute('data-saved-label');
        }
      });
    </script>
  </body>
</html>

<style>
  :root {
    --color-primary: #1e1b4b;
    --color-accent: #c9952e;
    --color-accent-light: #fef3c7;
    --color-bg: #fcfbf9;
    --color-surface: #ffffff;
    --color-text: #1f2937;
    --color-muted: #6b7280;
    --color-border: #e5e7eb;
    --color-tag-bg: #fef3c7;
    --color-tag-text: #92400e;
    --font-serif: 'Playfair Display', Georgia, 'Noto Serif TC', serif;
    --font-sans: 'Inter', 'Noto Sans TC', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,0.06);
    --shadow-lg: 0 8px 30px rgba(0,0,0,0.08);
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: var(--font-sans);
    color: var(--color-text);
    background-color: var(--color-bg);
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    -webkit-font-smoothing: antialiased;
    line-height: 1.6;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-serif);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-primary);
  }

  .main-content {
    max-width: 1024px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    min-height: calc(100vh - 160px);
  }

  a { color: var(--color-accent); text-decoration: none; transition: color 0.2s; }
  a:hover { color: #a67a1e; }

  img { max-width: 100%; height: auto; border-radius: var(--radius-sm); }

  ::selection {
    background: var(--color-accent-light);
    color: var(--color-primary);
  }
  @media (max-width: 767px) {
    .main-content { padding: 1.5rem 1rem; }
  }
</style>
