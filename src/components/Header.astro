---
import { t, type Locale } from '../i18n/utils';

export interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const nav = [
  { href: '/', label: 'navHome', enHref: '/en/' },
  { href: '/album', label: 'navAlbum', enHref: '/en/album' },
  { href: '/daily-classical', label: 'navDaily', enHref: '/en/daily-classical' },
];

function isActive(href: string, enHref: string): boolean {
  const p = locale === 'zh' ? href : enHref;
  if (p === '/' || p === '/en/') return currentPath === p;
  return currentPath.startsWith(p);
}

function langSwitchHref(path: string, from: Locale): string {
  const alt = from === 'zh' ? 'en' : 'zh';
  if (alt === 'zh') return path.replace(/^\/en/, '') || '/';
  return `/en${path}`;
}
---

<header class="site-header">
  <div class="header-inner">
    <a href={locale === 'zh' ? '/' : '/en/'} class="logo">
      <span class="logo-icon">♪</span>
      <span class="logo-text">{t('siteTitle', locale)}</span>
    </a>
    <nav class="main-nav">
      {nav.map((item) => (
        <a
          href={locale === 'zh' ? item.href : item.enHref}
          class:list={{ active: isActive(item.href, item.enHref) }}
        >
          {t(item.label, locale)}
        </a>
      ))}
    </nav>
    <a href={langSwitchHref(currentPath, locale)} class="lang-switch">{t('switchLang', locale)}</a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-primary);
    white-space: nowrap;
  }
  .logo-icon {
    font-size: 1.4rem;
    color: var(--color-accent);
  }
  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
  }
  .main-nav {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }
  .main-nav a {
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
  }
  .main-nav a:hover { color: var(--color-primary); background: #f3f4f6; }
  .main-nav a.active { color: var(--color-primary); background: var(--color-accent-light); }
  .lang-switch {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.35rem 0.9rem;
    border: 1.5px solid var(--color-accent);
    border-radius: 20px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .lang-switch:hover {
    background: var(--color-accent);
    color: #fff;
  }
</style>
