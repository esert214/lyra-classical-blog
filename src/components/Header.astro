---
import { t, type Locale } from '../i18n/utils';

export interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const nav = [
  { href: '/', label: 'navHome', enHref: '/en/' },
  { href: '/album', label: 'navAlbum', enHref: '/en/album' },
  { href: '/daily-classical', label: 'navDaily', enHref: '/en/daily-classical' },
  { href: '/about', label: 'navAbout', enHref: '/en/about' },
];

function isActive(href: string, enHref: string): boolean {
  const p = locale === 'zh' ? href : enHref;
  if (p === '/' || p === '/en/') return currentPath === p;
  return currentPath.startsWith(p);
}

function langSwitchHref(path: string, from: Locale): string {
  const alt = from === 'zh' ? 'en' : 'zh';
  if (alt === 'zh') return path.replace(/^\/en/, '') || '/';
  return `/en${path}`;
}
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href={locale === 'zh' ? '/' : '/en/'} class="logo">
      <span class="logo-icon">♪</span>
      <span class="logo-text">{t('siteTitle', locale)}</span>
    </a>
    <nav class="main-nav">
      {nav.map((item) => (
        <a
          href={locale === 'zh' ? item.href : item.enHref}
          class:list={{ active: isActive(item.href, item.enHref) }}
        >
          {t(item.label, locale)}
        </a>
      ))}
    </nav>
    <div class="header-actions">
      <a href={locale === 'zh' ? '/bookmarks' : '/en/bookmarks'} class="nav-icon-link" title={t('bookmarks', locale)}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
      </a>
      <a href={langSwitchHref(currentPath, locale)} class="lang-switch">{t('switchLang', locale)}</a>
      <button class="hamburger" aria-label="Menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>
<script>
  const header = document.getElementById('site-header');
  const hamburger = header.querySelector('.hamburger');
  const nav = header.querySelector('.main-nav');
  hamburger.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true' ? false : true;
    hamburger.setAttribute('aria-expanded', expanded);
    header.classList.toggle('nav-open', expanded);
  });
  document.addEventListener('click', (e) => {
    if (!header.contains(e.target) && header.classList.contains('nav-open')) {
      header.classList.remove('nav-open');
      hamburger.setAttribute('aria-expanded', 'false');
    }
  });
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-primary);
    white-space: nowrap;
  }
  .logo-icon {
    font-size: 1.4rem;
    color: var(--color-accent);
  }
  .logo-text {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 700;
  }
  .main-nav {
    display: flex;
    gap: 0.25rem;
    flex: 1;
  }
  .main-nav a {
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
  }
  .main-nav a:hover { color: var(--color-primary); background: #f3f4f6; }
  .main-nav a.active { color: var(--color-primary); background: var(--color-accent-light); }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .nav-icon-link { display: flex; align-items: center; padding: 0.35rem; color: var(--color-muted); text-decoration: none; transition: color 0.15s; }
  .nav-icon-link:hover { color: var(--color-accent); }
  .lang-switch {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.35rem 0.9rem;
    border: 1.5px solid var(--color-accent);
    border-radius: 20px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .lang-switch:hover {
    background: var(--color-accent);
    color: #fff;
  }
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 32px;
    height: 32px;
    padding: 4px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .hamburger span {
    display: block;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }
  .nav-open .hamburger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .nav-open .hamburger span:nth-child(2) { opacity: 0; }
  .nav-open .hamburger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  @media (max-width: 767px) {
    .header-inner { gap: 0.5rem; padding: 0 1rem; }
    .logo-text { font-size: 1rem; }
    .main-nav {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      background: rgba(255,255,255,0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-border);
      box-shadow: var(--shadow-lg);
      padding: 0.5rem 0;
    }
    .nav-open .main-nav { display: flex; }
    .main-nav a {
      padding: 0.7rem 1.25rem;
      border-radius: 0;
      font-size: 0.95rem;
    }
    .hamburger { display: flex; }
  }
</style>
