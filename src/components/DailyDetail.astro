---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { t, type Locale } from '../i18n/utils';
import AuthorBio from './AuthorBio.astro';

export interface Props { locale: Locale; slug: string }

const { locale, slug } = Astro.props;

const entries = await getCollection('daily-classical', (e) => e.data.locale === locale && e.data.slug === slug);
if (entries.length === 0) return Astro.redirect('/404');
const entry = entries[0];
const { data } = entry;
const { Content } = await render(entry);
const prefix = locale === 'zh' ? '' : '/en';
const fmt = (d: Date) => locale === 'zh' ? `${d.getFullYear()} 年 ${d.getMonth() + 1} 月 ${d.getDate()} 日` : d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout locale={locale} title={`${data.title} — ${t('siteTitle', locale)}`}>
  <nav class="breadcrumb">
    <a href={prefix || '/'}>{t('navHome', locale)}</a>
    <span class="sep">›</span>
    <a href={`${prefix}/daily-classical`}>{t('navDaily', locale)}</a>
    <span class="sep">›</span>
    <span>{data.title}</span>
  </nav>

  <article>
    <header class="article-header">
      <div class="piece-badge">♪</div>
      <div class="header-text">
        <h1>{data.title}</h1>
        <p class="subtitle">{data.composer.name} · {data.period} · {data.year}</p>
        <time class="pub-date">{t('published', locale)} {fmt(data.date)}</time>
        <button
          class="bookmark-btn"
          data-bookmark={JSON.stringify({ title: data.title, url: Astro.url.pathname, coverImage: data.coverImage || '', type: 'daily' })}
          data-save-label={t('saveArticle', locale)}
          data-saved-label={t('savedArticle', locale)}
          aria-label={t('saveArticle', locale)}
        >
          <svg class="bookmark-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          <span class="bookmark-label">{t('saveArticle', locale)}</span>
        </button>
      </div>
    </header>
    {data.coverImage && <img class="cover" src={data.coverImage} alt={data.title} />}

    <div class="content"><Content /></div>

    <section class="composer-section">
      <h2>✍️ {t('composerInfo', locale)}</h2>
      <div class="composer-card">
        <div class="composer-avatar">{data.composer.name.charAt(0)}</div>
        <div class="composer-body">
          <strong>{data.composer.name}</strong>
          {data.composer.bio && <p class="composer-bio">{data.composer.bio}</p>}
        </div>
      </div>
    </section>

    <section class="recordings-section">
      <h2>💿 {t('alternativeRecording', locale)}</h2>
      <div class="recording-list">
        {data.notableRecordings.map((rec) => (
          <div class="recording-card">
            <div class="rec-num">♪</div>
            <div class="rec-body">
              <strong>{rec.performer}</strong>
              <p class="rec-meta">{rec.label} · {rec.year}</p>
              {rec.notes && <p class="rec-notes">{rec.notes}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <AuthorBio locale={locale} />

    <div class="tags">
      {data.tags.map((tag) => <a href={`${prefix}/tags/${encodeURIComponent(tag)}`} class="tag">{tag}</a>)}
    </div>
  </article>
</Layout>

<style>
  .breadcrumb { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 1.5rem; font-size: 0.82rem; color: var(--color-muted); }
  .breadcrumb a { color: var(--color-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb .sep { color: var(--color-border); }
  .breadcrumb span:last-child { color: var(--color-text); font-weight: 500; }
  .article-header { display: flex; gap: 1rem; align-items: flex-start; margin-bottom: 2rem; }
  .piece-badge { font-size: 2rem; color: var(--color-accent); line-height: 1; flex-shrink: 0; margin-top: 0.2rem; }
  .header-text h1 { font-size: 1.85rem; margin: 0; }
  .subtitle { color: var(--color-muted); margin: 0.3rem 0 0; font-size: 0.92rem; }
  .pub-date { display: block; margin-top: 0.4rem; font-size: 0.82rem; color: var(--color-muted); }
  .bookmark-btn { display: inline-flex; align-items: center; gap: 0.35rem; margin-top: 0.6rem; padding: 0.35rem 0.75rem; font-size: 0.8rem; font-family: var(--font-sans); border: 1px solid var(--color-border); border-radius: 999px; background: var(--color-surface); color: var(--color-muted); cursor: pointer; transition: all 0.15s; }
  .bookmark-btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .bookmark-btn.saved { background: var(--color-accent-light); border-color: var(--color-accent); color: var(--color-accent); }
  .bookmark-btn.saved .bookmark-icon { fill: var(--color-accent); }
  .cover { width: 100%; max-height: 360px; object-fit: cover; border-radius: var(--radius-md); margin-bottom: 2rem; box-shadow: var(--shadow-md); }
  .content { line-height: 1.85; font-size: 1rem; color: var(--color-text); }
  .content :global(p) { margin: 1.2em 0; }
  .composer-section { margin: 2.5rem 0; }
  .composer-section h2 { font-family: var(--font-sans); font-size: 1rem; color: var(--color-primary); margin-bottom: 1rem; }
  .composer-card { display: flex; gap: 1rem; align-items: flex-start; padding: 1.125rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); }
  .composer-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--color-accent-light); color: var(--color-tag-text); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.95rem; flex-shrink: 0; }
  .composer-body strong { font-size: 0.95rem; display: block; }
  .composer-bio { font-size: 0.85rem; color: var(--color-muted); margin: 0.35rem 0 0; line-height: 1.6; }
  .recordings-section { margin: 2.5rem 0; }
  .recordings-section h2 { font-family: var(--font-sans); font-size: 1rem; color: var(--color-primary); margin-bottom: 1rem; }
  .recording-list { display: grid; gap: 0.75rem; }
  .recording-card { display: flex; gap: 0.85rem; align-items: flex-start; padding: 1rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); transition: box-shadow 0.15s; }
  .recording-card:hover { box-shadow: var(--shadow-md); }
  .rec-num { font-size: 1.2rem; color: var(--color-accent); flex-shrink: 0; line-height: 1.4; }
  .rec-body strong { font-size: 0.95rem; }
  .rec-meta { color: var(--color-muted); font-size: 0.82rem; margin: 0.2rem 0; }
  .rec-notes { color: var(--color-text); font-size: 0.88rem; margin: 0.35rem 0 0; line-height: 1.6; }
  .tags { margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag { padding: 2px 12px; background: var(--color-tag-bg); color: var(--color-tag-text); border-radius: 12px; font-size: 0.78rem; font-weight: 500; }
  @media (max-width: 767px) {
    .header-text h1 { font-size: 1.35rem; }
    .cover { max-height: 240px; }
    .article-header { gap: 0.65rem; }
    .piece-badge { font-size: 1.5rem; }
  }
</style>
