---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { t, type Locale } from '../i18n/utils';

export interface Props { locale: Locale }

const { locale } = Astro.props;

const albums = await getCollection('album', (e) => e.data.locale === locale);
const dailyEntries = await getCollection('daily-classical', (e) => e.data.locale === locale);

const recentAlbums = albums.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 5);
const recentDaily = dailyEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 5);
const prefix = locale === 'zh' ? '' : '/en';
---

<Layout locale={locale} title={t('siteTitle', locale)}>
  <section class="hero">
    <div class="hero-overlay">
      <h1>{t('siteTitle', locale)}</h1>
      <p class="hero-sub">{t('siteDescription', locale)}</p>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2><a href={`${prefix}/album`}>{t('albumSection', locale)}</a></h2>
      <span class="count">{t('albumCount', locale, { count: albums.length })}</span>
    </div>
    <div class="card-grid">
      {recentAlbums.map((entry) => (
        <a class="card" href={`${prefix}/album/${entry.data.slug}`}>
          {entry.data.coverImage && <img class="card-img" src={entry.data.coverImage} alt="" loading="lazy" />}
          <div class="card-body">
            <h3>{entry.data.album}</h3>
            <p class="card-meta">{entry.data.artist} · {entry.data.releaseDate}</p>
            {entry.data.genre && <span class="card-tag">{entry.data.genre}</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2><a href={`${prefix}/daily-classical`}>{t('dailySection', locale)}</a></h2>
      <span class="count">{t('dailyCount', locale, { count: dailyEntries.length })}</span>
    </div>
    <div class="card-grid">
      {recentDaily.map((entry) => (
        <a class="card" href={`${prefix}/daily-classical/${entry.data.slug}`}>
          <div class="card-body">
            <h3>{entry.data.title}</h3>
            <p class="card-meta">{entry.data.composer.name} · {entry.data.period}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    text-align: center;
    padding: 6rem 0 5rem;
    border-radius: var(--radius-lg);
    margin-bottom: 1rem;
    background-image: url('https://images.unsplash.com/photo-1719753458800-c09cfb167ac5?w=1200&q=80');
    background-size: cover;
    background-position: center 30%;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(30,27,75,0.75) 0%, rgba(30,27,75,0.4) 100%);
  }
  .hero-overlay { position: relative; z-index: 1; padding: 0 1.5rem; }
  .hero h1 { font-size: 2.6rem; margin: 0; color: #fff; text-shadow: 0 2px 12px rgba(0,0,0,0.25); }
  .hero-sub { color: rgba(255,255,255,0.85); margin-top: 0.6rem; font-size: 1.05rem; text-shadow: 0 1px 6px rgba(0,0,0,0.2); }
  .section { margin-top: 3rem; }
  .section-header { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 1rem; }
  .section-header h2 { margin: 0; font-size: 1.25rem; }
  .section-header h2 a { color: var(--color-primary); text-decoration: none; }
  .section-header h2 a:hover { color: var(--color-accent); }
  .count { color: var(--color-muted); font-size: 0.8rem; }
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .card {
    display: flex; flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none; color: inherit;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
  }
  .card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }
  .card-img { width: 100%; height: 160px; object-fit: cover; }
  .card-body { padding: 1rem 1.125rem 1.125rem; }
  .card-body h3 { margin: 0 0 0.25rem; font-size: 1rem; }
  .card-meta { color: var(--color-muted); font-size: 0.82rem; margin: 0; }
  .card-tag {
    display: inline-block; margin-top: 0.5rem;
    font-size: 0.72rem; padding: 1px 8px;
    background: var(--color-accent-light); color: var(--color-tag-text);
    border-radius: 10px;
  }
</style>
